# Copy to .env locally (never commit .env). Required for digital twin chat API.
OPENAI_API_KEY=

# Optional — full twin knowledge as markdown (same content as personal_profile.md).
# Easier: keep personal_profile.md locally (gitignored). For Vercel: paste into this var in
# Project → Settings → Environment Variables (multiline supported). Do not commit real content.
# PERSONAL_PROFILE_MARKDOWN=

# Optional — log each digital twin Q&A to a private GitHub repo.
# 1) Create a private repo, e.g. digital_twin_logs.
# 2) Generate a fine-grained PAT with Contents: Read and write, scoped only to that repo.
# 3) Set these vars in .env and in your hosting provider (e.g. Vercel):
# CHAT_LOG_GITHUB_TOKEN=ghp_...
# CHAT_LOG_GITHUB_REPO_OWNER=r1ashwin
# CHAT_LOG_GITHUB_REPO_NAME=digital_twin_logs
# CHAT_LOG_GITHUB_LOG_PATH=logs.csv
