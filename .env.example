# Copy to .env locally (never commit .env). Required for digital twin chat API.
OPENAI_API_KEY=

# Optional — full twin knowledge as markdown (same content as personal_profile.md).
# Easier: keep personal_profile.md locally (gitignored). For Vercel: paste into this var in
# Project → Settings → Environment Variables (multiline supported). Do not commit real content.
# PERSONAL_PROFILE_MARKDOWN=
